# Copy to .env and fill in values for local development.
# Cloud Run reads these as environment variables set at deploy time.

# GCP core
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# GCS bucket created by scripts/setup_gcp.py
GCS_BUCKET=your-project-id-legal-rag

# Vertex AI Vector Search — populated by scripts/setup_gcp.py
VECTOR_SEARCH_INDEX_ID=1234567890123456789
VECTOR_SEARCH_ENDPOINT_ID=1234567890123456789
